# ─────────────────────────────────────────────────────────────────────────────
# MSU-ZS ROTC ATTENDANCE SYSTEM — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Digital ID Public Portal ──────────────────────────────────────────────────
# This is the public web URL where cadets can search and view their digital ID.
# OPTION A: If you deploy the web version (expo export --platform web + hosting):
#   Set this to your real deployed URL, e.g. https://rotc-mszs.netlify.app
# OPTION B: If you only publish the mobile APK (no web):
#   Leave this empty — the app will auto-generate a deep link (exp:// or your scheme)
#   that works on any device with the app installed.
EXPO_PUBLIC_DIGITAL_ID_PORTAL_URL=https://rotc1-eight.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Use remote Supabase (0 = remote/production, 1 = local dev)
EXPO_PUBLIC_USE_LOCAL_SUPABASE=0
# EXPO_PUBLIC_LOCAL_SUPABASE_URL=http://192.168.1.xxx:54321
