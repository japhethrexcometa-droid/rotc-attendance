{
  "expo": {
    "name": "MSU-ZS ROTC Attendance",
    "slug": "rotc-mszs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/batch-logo.png",
    "scheme": "rotcmszs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.msu.zs.rotc.attendance"
    },
    "android": {
      "package": "edu.msu.zs.rotc.attendance",
      "adaptiveIcon": {
        "backgroundColor": "#1F3D2B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/batch-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1F3D2B",
          "dark": {
            "backgroundColor": "#1F3D2B"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4eb3085b-243a-41f0-aa41-850d1f41ca9d"
      }
    }
  }
}
