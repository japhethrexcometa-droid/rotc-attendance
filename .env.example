EXPO_PUBLIC_DIGITAL_ID_PORTAL_URL=https://rotc1-eight.vercel.app

# Supabase connection mode
# - Default (recommended): remote Supabase (works on physical devices without Docker/LAN setup)
# - Local Supabase: requires Docker Desktop + `supabase start`, and your phone must reach your PC on the LAN
#
# Set to 1/true to use local Supabase (http://<dev-host>:54321)
# EXPO_PUBLIC_USE_LOCAL_SUPABASE=1
#
# Optional override for local Supabase URL (useful if auto-detect fails)
# EXPO_PUBLIC_LOCAL_SUPABASE_URL=http://192.168.1.251:54321
